# Copie este arquivo para ".env" e preencha se quiser customizar.
# NUNCA suba o arquivo ".env" (com valores reais) para o GitHub.

# Chave secreta do Flask. Gere uma aleatória com:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Pasta onde os .txt enviados ficam guardados temporariamente
UPLOAD_DIR=

# Pasta padrão de saída dos .xlsx (quando o campo "destino" for deixado em branco)
DEFAULT_OUTPUT_DIR=
